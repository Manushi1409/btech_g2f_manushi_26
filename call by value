#include <stdio.h>

// Function prototype for swap, using call by value (int a, int b)
void swap(int a, int b) {
    int temp;
    temp = a;
    a = b;
    b = temp;
    printf("Inside function (after swap): a = %d, b = %d\n", a, b); // Changes are visible here
}

int main() {
    int num1 = 10;
    int num2 = 20;

    printf("Before function call: num1 = %d, num2 = %d\n", num1, num2);

    // Calling the swap function by value
    swap(num1, num2);

    printf("After function call (in main): num1 = %d, num2 = %d\n", num1, num2); // Original values are unchanged

    return 0;
}
